# Copy to .env and fill in. Do not commit .env.

SUPABASE_URL=
SUPABASE_ANON_KEY=

# PostHog analytics (optional)
ANALYTICS_ENABLED=true
POSTHOG_API_KEY=
# EU Cloud: https://eu.i.posthog.com  |  US Cloud: https://us.i.posthog.com
POSTHOG_HOST=https://eu.i.posthog.com

# In-app purchase (optional — false enables demo premium toggle)
IAP_ENABLED=false
IAP_PREMIUM_PRODUCT_ID_IOS=crossball_premium
IAP_PREMIUM_PRODUCT_ID_ANDROID=crossball_premium

# Development: when true, premium/IAP is ignored and free tier is forced
FORCE_FREE_TIER=false

# AdMob (optional for MVP scaffold)
ADMOB_ENABLED=false
ADMOB_USE_TEST_ADS=true
ADMOB_ANDROID_APP_ID=ca-app-pub-3940256099942544~3347511713
ADMOB_IOS_APP_ID=ca-app-pub-3940256099942544~1458002511
ADMOB_BANNER_ANDROID=ca-app-pub-3940256099942544/6300978111
ADMOB_BANNER_IOS=ca-app-pub-3940256099942544/2934735716
ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-3940256099942544/1033173712
ADMOB_INTERSTITIAL_IOS=ca-app-pub-3940256099942544/4411468910
ADMOB_REWARDED_ANDROID=ca-app-pub-3940256099942544/5224354917
ADMOB_REWARDED_IOS=ca-app-pub-3940256099942544/1712485313

# Remote push (FCM) — optional; enable after Firebase + APNs setup (see docs/IOS_LAUNCH_GUIDE.md)
REMOTE_PUSH_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_IOS_API_KEY=
FIREBASE_IOS_APP_ID=
FIREBASE_ANDROID_API_KEY=
FIREBASE_ANDROID_APP_ID=

# RevenueCat (optional — not wired yet; native in_app_purchase is default)
# REVENUECAT_IOS_API_KEY=appl_xxxxxxxxxxxx
