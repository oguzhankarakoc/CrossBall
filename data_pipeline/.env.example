# Local Supabase CLI:
# DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
#
# Production (CrossBall project kseqeqpoouneaiymdzpq, region ap-south-1):
#
# 1) Supabase Dashboard → Connect → URI → Transaction pooler (recommended on Mac when
#    direct db.*:5432 times out). Copy the full string and paste below — do not hand-edit.
# DATABASE_URL=postgresql://postgres.kseqeqpoouneaiymdzpq:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
#
# 2) Session pooler (port 5432) — recommended for local dedupe-players / long jobs:
# DATABASE_URL=postgresql://postgres.kseqeqpoouneaiymdzpq:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
#
# 3) Direct (only if reachable from your Mac):
# DATABASE_URL=postgresql://postgres.kseqeqpoouneaiymdzpq:[PASSWORD]@db.kseqeqpoouneaiymdzpq.supabase.co:5432/postgres
#
# Test: ../../scripts/test_data_pipeline_db.sh
# Wrong password → FATAL (ENOTFOUND) tenant/user postgres.kseqeqpoouneaiymdzpq not found
DATABASE_URL=

