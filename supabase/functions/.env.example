# Phase 0 security — Supabase Edge Function secrets (set in dashboard or CLI)

# Staging/dev: allow verify-premium with platform=dev (IAP_ENABLED=false on client)
IAP_SKIP_VERIFY=true

# Production: set to true once Apple/Google receipt validation is wired
# IAP_STRICT_VERIFY=true

# Optional shared secret for manual premium activation in staging
# IAP_DEV_SECRET=your-staging-secret

# Product id must match client IAP_PREMIUM_PRODUCT_ID_*
IAP_PREMIUM_PRODUCT_ID=crossball_premium
